# Required
DISCORD_TOKEN=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_REPO=mejasonmejason/tootsies
DATABASE_URL=postgres://user:pass@localhost:5432/tootsies

# Perplexity Sonar search (optional, enhances /ask /recap /discourse with real-time trending context)
# Get an API key at https://docs.perplexity.ai
PERPLEXITY_API_KEY=

# SportsGameOdds (optional, enables live sports lines for /ask /discourse sports takes)
# Free Amateur tier covers NFL/NBA/MLB/NHL/CFB/CBB/UCL/MLS. Sign up at https://sportsgameodds.com
# Polymarket and Kalshi market data are public (no key needed) and are wired up unconditionally.
SPORTS_GAME_ODDS_API_KEY=

# /undo , Railway rollback
# RAILWAY_API_TOKEN: required for /undo to work. Generate at https://railway.com/account/tokens
RAILWAY_API_TOKEN=
# RAILWAY_SERVICE_ID: auto-injected by Railway at runtime. Only set explicitly if running off-Railway.
RAILWAY_SERVICE_ID=

# Optional
BOT_LOGS_VERBOSITY=milestones
HEALTH_PORT=8080
LOG_LEVEL=INFO
