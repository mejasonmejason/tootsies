# Required
DISCORD_TOKEN=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_REPO=mejasonmejason/tootsies
DATABASE_URL=postgres://user:pass@localhost:5432/tootsies

# /undo , Railway rollback
# RAILWAY_API_TOKEN: required for /undo to work. Generate at https://railway.com/account/tokens
RAILWAY_API_TOKEN=
# RAILWAY_SERVICE_ID: auto-injected by Railway at runtime. Only set explicitly if running off-Railway.
RAILWAY_SERVICE_ID=

# Optional
BOT_LOGS_VERBOSITY=milestones
HEALTH_PORT=8080
LOG_LEVEL=INFO
